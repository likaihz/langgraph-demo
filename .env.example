# LangSmith tracing is optional for local experimentation.
LANGSMITH_TRACING=true

# api-key 从 https://smith.langchain.com/settings/apikeys 这里获取。登录后创建一个api key
LANGSMITH_API_KEY=your-langsmith-api-key-here
# LANGSMITH_PROJECT=langgraph-demo
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Configure the chat model used by src/app/agents/simple_agent.py.
OPENAI_MODEL=glm-5.1
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
